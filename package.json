{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "main": "main.js",
  "scripts": {
    "dev": "next dev -p 9002 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on http://localhost:9002 && electron .\"",
    "build:electron": "next build && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/db/seed.ts"
  },
  "build": {
    "appId": "com.meditrack.pro",
    "productName": "MediTrack Pro",
    "files": [
      "out/**/*",
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
